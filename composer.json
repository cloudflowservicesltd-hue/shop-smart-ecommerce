{
    "name": "whatsapi/cloud",
    "description": "WhatsAPI Cloud - WhatsApp API SaaS Platform",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^6.8 || ^7.0",
        "phpmailer/phpmailer": "^6.8",
        "guzzlehttp/guzzle": "^7.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"array_map(function($dir){@mkdir($dir, 0755, true);}, ['public/storage/sessions', 'public/storage/uploads', 'public/storage/qr-codes']);\"" 
        ]
    }
}