# ===========================================
# ShopSmart E-Commerce Application
# ===========================================

# ─── App ───────────────────────────────────
APP_NAME="AI-Powered Ecommerce & POS"
APP_ENV=development
APP_DEBUG=true
APP_URL=
APP_TIMEZONE=Africa/Nairobi
APP_CURRENCY=KES
APP_CURRENCY_SYMBOL=KSh

# ─── Database (MySQL) ─────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uydirsqz_shop
DB_USERNAME=uydirsqz_shop
DB_PASSWORD=Steve@2030

# ─── Session ───────────────────────────────
SESSION_LIFETIME=7200
SESSION_NAME=ecommerce_session

# ─── Mail (SMTP) ──────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=ShopSmart
MAIL_FROM_EMAIL=

# ─── Upload ────────────────────────
UPLOAD_MAX_SIZE=5242880

# ─── AI ────────────────────────────
AI_ENABLED=true
AI_MODEL=gpt-4