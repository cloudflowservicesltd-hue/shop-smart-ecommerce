# ============================================================
# ShopSmart E-Commerce & POS — Environment Configuration
# ============================================================
# Copy this file to .env on your server and fill in the values.
# Values can also be set/overridden via Admin > Settings in the dashboard.
# ============================================================

# ── App ────────────────────────────────────────────────────
APP_NAME=ShopSmart
APP_ENV=production
APP_DEBUG=false
APP_URL=https://shop.cloudonehost.top
APP_TIMEZONE=Africa/Nairobi
APP_CURRENCY=KES
APP_CURRENCY_SYMBOL=KSh

# ── Database (MySQL on hosting) ───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_NAME=ecommerce_session

# ── Upload ────────────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880

# ── Mail / SMTP ───────────────────────────────────────────
# These are defaults. Override via Admin > Settings > Email.
MAIL_HOST=mail.cloudonehost.top
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_NAME=ShopSmart
MAIL_FROM_EMAIL=

# ── IntaSend Payment Gateway ──────────────────────────────
# Get keys from https://app.intasend.com > Settings > API Keys
# IMPORTANT: Use sandbox keys when test mode is ON, live keys when OFF
INTASEND_PUBLISHABLE_KEY=
INTASEND_SECRET_KEY=
INTASEND_TEST_ENVIRONMENT=true

# ── Pesapal Payment Gateway ──────────────────────────────
# Get credentials from https://developer.pesapal.com
# IMPORTANT: Use sandbox credentials when test mode is ON
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_TEST_MODE=true

# ── AI (Optional) ────────────────────────────────────────
AI_ENABLED=true
AI_MODEL=gpt-4

# ── GitHub Token (for deployment) ─────────────────────────
# Used by deployment scripts — keep this secret
GITHUB_TOKEN=