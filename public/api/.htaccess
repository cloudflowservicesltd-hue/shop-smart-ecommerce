<IfModule mod_rewrite.c>
    RewriteEngine On

    # /api/pos/holds/restore/5 → serves pos/holds.php (PATH_INFO = /restore/5)
    RewriteRule ^pos/holds/. holds.php [L,QSA]

    # /api/pos/holds/5 → serves pos/holds.php (PATH_INFO = /5)
    # (already handled by the rule above)

    # /api/commissions/pay/5 → serves commissions/index.php
    RewriteRule ^commissions/pay/. index.php [L,QSA]
</IfModule>