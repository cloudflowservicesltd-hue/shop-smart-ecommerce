<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent MultiViews
    Options -MultiViews

    # Handle Authorization Header (for API auth)
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ═══════════════════════════════════════════════════════════════
    # CRITICAL: Route ALL /api/* requests through index.php
    # This prevents the web server from serving API paths as
    # static files/directories (which would cause 403 errors).
    # ALL API routing is handled by the PHP Router.
    # ═══════════════════════════════════════════════════════════════
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^(.*)$ index.php [QSA,L]

    # Serve existing files directly (static assets)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Serve existing directories directly
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite everything else to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Prevent directory listing and MultiViews
Options -Indexes -MultiViews

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 120
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>