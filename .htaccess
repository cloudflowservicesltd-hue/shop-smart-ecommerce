<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent MultiViews (content negotiation) which can cause unexpected URL matching
    Options -MultiViews -Indexes

    # Redirect all requests to public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Deny access to sensitive files
<FilesMatch "\.(env|log|sqlite|sh|sql|bak|swp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to hidden files (e.g. .git, .env)
<DirectoryMatch "^\.">
    Order allow,deny
    Deny from all
</DirectoryMatch>